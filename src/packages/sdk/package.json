{
  "name": "@semble.so/api",
  "version": "0.0.1",
  "description": "A fully-typed Semble API client",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "release": "npm run build && npm publish"
  },
  "dependencies": {
    "@ts-rest/core": "^3.51.0",
    "@semble/contract": "*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}

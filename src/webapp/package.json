{
  "name": "semble-webapp",
  "version": "0.1.0",
  "private": true,
  "manifest": {
    "name": "Semble",
    "permissions": [
      "activeTab",
      "storage"
    ],
    "key": "$CRX_PUBLIC_KEY"
  },
  "scripts": {
    "dev": "PORT=4000 NODE_OPTIONS='--dns-result-order=ipv4first' next dev --turbopack",
    "dev:prod": "NODE_ENV=production PORT=4000 next dev",
    "dev:extension": "plasmo dev",
    "build": "next build",
    "build:prod": "NODE_ENV=production next build",
    "build:extension": "NODE_ENV=production plasmo build",
    "package:extension": "plasmo package",
    "start": "PORT=4000 next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@mantine/code-highlight": "9.0.0",
    "@mantine/core": "9.0.0",
    "@mantine/dates": "9.0.0",
    "@mantine/dropzone": "9.0.0",
    "@mantine/form": "9.0.0",
    "@mantine/hooks": "9.0.0",
    "@mantine/modals": "9.0.0",
    "@mantine/notifications": "9.0.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.3",
    "@semble/types": "*",
    "@tanstack/react-query": "^5.85.5",
    "@types/mdx": "^2.0.13",
    "@vercel/analytics": "^1.5.0",
    "capnweb": "^0.6.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "next": "16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-error-boundary": "^6.0.0",
    "react-force-graph": "^1.48.2",
    "react-force-graph-2d": "^1.29.1",
    "react-icons": "^5.5.0",
    "shiki": "^3.20.0",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.332",
    "@types/node": "^20.10.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "^26.1.0",
    "plasmo": "^0.90.5",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5",
    "storybook": "^10.3.6",
    "@storybook/nextjs-vite": "^10.3.6",
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "vite": "^8.0.10",
    "eslint-plugin-storybook": "^10.3.6",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
